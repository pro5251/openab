# ==============================================================================
# OpenAB 環境變數配置 (Gemini Agent)
# ==============================================================================
# 使用方式:
#   1. 填入您的實際 API Keys
#   2. 執行: source .env  (或在腳本中使用 set -a; source .env; set +a)
#   3. 執行: ./run-openab.sh gemini
# ==============================================================================

# ============== 必要設定 ==============

# Discord Bot Token (必填) — run-openab.sh 單一 agent (gemini) 專用
# 從 https://discord.com/developers/applications 取得
DISCORD_BOT_TOKEN_GEMINI=YOUR_DISCORD_BOT_TOKEN_GEMINI

# Gemini API Key (必填)
# 從 https://aistudio.google.com/app/apikey 取得
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# 注意: GOOGLE_API_KEY 會自動從 GEMINI_API_KEY 複製 (run-openab.sh 第 76 行處理)


# ============== 選填設定 (其他 Agents) ==============

# Claude API Key (僅在使用 claude agent 時需要)
# export ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# OpenAI API Key (僅在使用 codex agent 時需要)
# export OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# GitHub Copilot Token (僅在使用 copilot agent 時需要)
# export COPILOT_GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE


# ============== MCP 工具設定 (選填) ==============
# 啟用 MCP 工具需要編輯 mcp-configs/gemini.json 並設定對應的環境變數
# 預設已配置 GitHub MCP Server

# GitHub Personal Access Token (用於 GitHub MCP Server)
# 建立 Token: https://github.com/settings/tokens (需要 repo 權限)
COPILOT_GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# 其他常用 MCP Servers (範例)：
# ----------------------------------------
# Figma
# 建立 Token: https://help.figma.com/hc/en-us/articles/8085703771159-Manage-personal-access-tokens
FIGMA_API_KEY=YOUR_FIGMA_API_KEY_HERE

# Atlassian Jira
# export ATLASSIAN_SITE_NAME=your-site-name
# export ATLASSIAN_USER_EMAIL=your-email@example.com
# export ATLASSIAN_API_TOKEN=YOUR_JIRA_API_TOKEN_HERE

# ============== 多 Agent 設定 ==============
# 每個 agent 對應一個獨立的 Discord Bot Token
# 請至 https://discord.com/developers/applications 分別建立 5 個 Bot

DISCORD_BOT_TOKEN_MEICHANGSU=YOUR_DISCORD_BOT_TOKEN_MEICHANGSU   # 梅長蘇 — Architect
DISCORD_BOT_TOKEN_JIANCHEN=YOUR_DISCORD_BOT_TOKEN_JIANCHEN       # 簡晨   — Backend
DISCORD_BOT_TOKEN_YANYUJIN=YOUR_DISCORD_BOT_TOKEN_YANYUJIN       # 言豫津 — Frontend
DISCORD_BOT_TOKEN_MENGZHI=YOUR_DISCORD_BOT_TOKEN_MENGZHI         # 蒙摯   — Ops
DISCORD_BOT_TOKEN_XIADONG=YOUR_DISCORD_BOT_TOKEN_XIADONG         # 夏冬   — QA

# 專案根目錄（掛載進容器為 /workspace）
PROJECT_DIR=/mnt/d/github/openab/workspace



# Rust 日誌等級 (debug / info / warn / error)
RUST_LOG=openab=debug



# Slack
# export SLACK_BOT_TOKEN=xoxb-YOUR-TOKEN
# export SLACK_TEAM_ID=YOUR_TEAM_ID

COPILOT_GITHUB_TOKEN=YOUR_COPILOT_GITHUB_TOKEN
